# Copy to .env and fill in. RepoDocMake loads .env automatically (CLI runs).
# .env is git-ignored — never commit real keys.

# --- OpenRouter (Claude via OpenRouter gateway) ---
REPODOCMAKE_LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-...
# Optional: pick the model (default: openrouter/anthropic/claude-sonnet-4)
# REPODOCMAKE_LLM_MODEL=openrouter/anthropic/claude-3.5-sonnet

# --- Anthropic (Claude) direct ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Other providers ---
# REPODOCMAKE_LLM_PROVIDER=gemini
# GEMINI_API_KEY=AIza...
# OPENAI_API_KEY=sk-...
